# Admin login credentials (used only once by `npm run seed` to create the admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Long random string used to sign admin session tokens.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string

# Path to the SQLite database file (relative to project root)
DATABASE_PATH=./data/sobitov.db
